{
  "name": "error-sync-lib",
  "version": "0.3.3",
  "private": "true",
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "rm -rf ./lib/esm && tsc",
    "build:cjs": "rm -rf ./lib/cjs && tsc --module commonjs --outDir lib/cjs",
    "lint": "eslint src --ext .ts",
    "lint:types": "tsc --noEmit",
    "test": "jest --passWithNoTests src",
    "dev": "npm run build:cjs && node lib/cjs/manualTest.js"
  },
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "engines": {
    "node": "^22"
  },
  "dependencies": {
    "@atlaskit/editor-json-transformer": "^8.30.0",
    "@atlaskit/editor-wikimarkup-transformer": "^11.19.0",
    "@types/jsurl": "^0.1.2",
    "aws-sdk": "^2.981.0",
    "jira.js": "^5.2.2",
    "jsurl": "^0.1.5",
    "newrelic-api-client": "^0.1.7",
    "opsgenie-sdk": "^0.5.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.129",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11"
  }
}
